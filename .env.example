# Copy this file to .env and fill in your own DashScope API key.
# Never commit your real .env file to GitHub.
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional: override the Gradio launch port.
# GRADIO_SERVER_PORT=7860

# Optional: enable Redis-backed rate limiting and cache.
# If REDIS_URL is empty, the FastAPI backend falls back to in-memory storage.
# REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT=10
# RATE_WINDOW_SECONDS=60
# CACHE_TTL_SECONDS=3600
